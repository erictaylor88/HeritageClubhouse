# Heritage Clubhouse — environment variables
# Real values live in Vercel project settings (and your password manager),
# never in the repo. See heritage-clubhouse-deployment-config.md.

# Supabase (client-safe; RLS-enforced)
NEXT_PUBLIC_SUPABASE_URL=https://pcwpjdxpmgvlzefycbrb.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server only — NEVER expose with NEXT_PUBLIC, never commit
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # public share route + cache write-through
GOLFCOURSE_API_KEY=your-golfcourse-api-key        # /api/courses/* proxy (P1)
RESEND_API_KEY=your-resend-key                    # production magic-link email (P2)
